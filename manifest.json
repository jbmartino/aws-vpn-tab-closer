{
  "manifest_version": 3,
  "name": "AWS VPN Tab Closer",
  "version": "1.0.0",
  "description": "Automatically closes the authentication tab left open by AWS VPN client after successful credential resubmission.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:35001/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
